        "@ai-sdk/openai": "^4.0.6",
        "@ai-sdk/provider-utils": "^5.0.10",
        "@filiks/database": "workspace:*",
        "@filiks/shared": "workspace:*",
        "@hono/zod-validator": "^0.8.0",
        "@sentry/bun": "^10.63.0",
        "@sentry/hono": "^10.63.0",
        "ai": "^7.0.13",
        "dotenv": "^17.4.2",
